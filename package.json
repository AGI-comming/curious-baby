{
  "name": "curious-baby",
  "version": "0.1.0",
  "description": "A local-first autonomous agent with memory, personality, permissions, and a tiny sense of wonder.",
  "type": "module",
  "bin": {
    "baby": "./dist/packages/cli/src/index.js",
    "curious-baby": "./dist/packages/cli/src/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build --config packages/dashboard/web/vite.config.ts",
    "build:ts": "tsc -p tsconfig.json",
    "build:dashboard": "vite build --config packages/dashboard/web/vite.config.ts",
    "test": "npm run build:ts && node --test tests/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "commander": "^14.0.0",
    "fastify": "^5.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.34",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3"
  }
}
